# Required
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — Anthropic model for onboarding replies (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional — LLM-based phase classifier (Qwen on Groq free tier)
# Get a free key at https://console.groq.com
GROQ_API_KEY=gsk_...
# CLASSIFY_BASE_URL=https://api.groq.com/openai/v1
# CLASSIFY_MODEL=qwen-qwq-32b

# Optional — comma-separated allowed origins (defaults to Vite dev server)
# CORS_ORIGINS=http://localhost:5173

# Optional — Langfuse observability (runs fine without these)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
